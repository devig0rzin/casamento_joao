NEXT_PUBLIC_PIX_KEY=coloque-a-chave-pix-real-aqui
NEXT_PUBLIC_PIX_KEY_TYPE=auto
NEXT_PUBLIC_PIX_MERCHANT_NAME=JOAO PEDRO E JESSICA
NEXT_PUBLIC_PIX_MERCHANT_CITY=COTIA
NEXT_PUBLIC_RSVP_EMAIL=casamento.joao.jessica.2026@gmail.com

# Use auto, email, phone, cpf, cnpj ou random.
# Para chave celular, use NEXT_PUBLIC_PIX_KEY_TYPE=phone.

# Opcional: habilita gravacao no Supabase para RSVP e intencoes de pagamento.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Nunca coloque senha real neste arquivo de exemplo. Use apenas .env.local.
SUPABASE_PROJECT_NAME=casamento_joao_jessica
SUPABASE_DB_PASSWORD=

# Envio automatico de confirmacao de presenca por SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=casamento.joao.jessica.2026@gmail.com
SMTP_PASSWORD=
EMAIL_FROM=casamento.joao.jessica.2026@gmail.com

# Opcional para teste local quando o Windows intercepta certificados TLS.
SMTP_TLS_REJECT_UNAUTHORIZED=true
